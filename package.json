{
  "name": "wacky-travel-ssr",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev ./public --compatibility-date=2026-03-25",
    "deploy": "wrangler pages deploy ./public --project-name=wacky-travel",
    "d1:exec": "wrangler d1 execute wacky-travel-db --file=./db/schema.sql",
    "d1:seed": "wrangler d1 execute wacky-travel-db --file=./db/seed.sql",
    "d1:migrate:travel": "wrangler d1 execute wacky-travel-db --file=./db/migrations/001_travel_affiliate_schema.sql",
    "d1:migrate:travel-settings": "wrangler d1 execute wacky-travel-db --file=./db/migrations/002_travel_exposure_settings.sql"
  },
  "devDependencies": {
    "wrangler": "^4.77.0"
  }
}
