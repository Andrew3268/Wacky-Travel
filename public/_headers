/assets/*
  Cache-Control: public, max-age=31536000, immutable

/favicon.ico
  Cache-Control: public, max-age=31536000, immutable

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/img/*
  Cache-Control: public, max-age=31536000, immutable

/*
  Content-Security-Policy: img-src 'self' data: blob: https://images.unsplash.com https://plus.unsplash.com https://*.r2.dev;
  Referrer-Policy: no-referrer

